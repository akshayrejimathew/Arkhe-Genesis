# --- THE ARKHÉ GENESIS SHIELD ---

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js & Build Outputs
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# Debug & Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# Secrets & Environment (THE MOST CRITICAL)
.env
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# System Files
.DS_Store
Thumbs.db

# --- GENOMIC DATA SAFETY ---
